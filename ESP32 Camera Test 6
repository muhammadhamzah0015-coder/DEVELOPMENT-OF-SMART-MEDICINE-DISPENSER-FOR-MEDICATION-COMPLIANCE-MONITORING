void updateOLED(String text) {
  // Only redraw if the text actually changed to save CPU time!
  if (text != lastOledText) {
    display.clearDisplay();
    display.setCursor(0, 10);
    display.print(text);
    display.display();
    lastOledText = text;
  }
}

