void sendCommandToAI(String cmd) {
  cmd.toCharArray(outgoingCommand.commandText, sizeof(outgoingCommand.commandText));
  esp_now_send(aiAssistantAddress, (uint8_t *) &outgoingCommand, sizeof(outgoingCommand));
  Serial.println("[ESP-NOW] Sent to AI: " + cmd);
}

void OnDataSent(const esp_now_send_info_t *info, esp_now_send_status_t status) { }

void OnDataRecv(const uint8_t * mac, const uint8_t *incomingDataBytes, int len) {
  memcpy(&incomingData, incomingDataBytes, sizeof(incomingData));
  
  if (incomingData.isPresent == true && camera_is_on == false) {
    Serial.println("\n[ESP-NOW] Ultrasonic detected patient: WAKING UP CAMERA");
    if (ei_camera_init()) {
      camera_is_on = true;
      analogWrite(FLASH_LED_PIN, 1);
