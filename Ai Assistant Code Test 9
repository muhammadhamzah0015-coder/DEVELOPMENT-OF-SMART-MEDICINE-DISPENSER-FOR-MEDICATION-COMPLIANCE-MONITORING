    esp_now_add_peer(&peerInfo);
  }
  
  audio.setPinout(I2S_BCLK, I2S_LRC, I2S_DOUT);
  audio.setVolume(20);
  audio.setConnectionTimeout(2000, 7200); 

  gptChat.setSystemPrompt(systemPrompt);
  gptChat.enableMemory(true);

