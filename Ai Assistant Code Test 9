bool isAllowedTime() {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo, 10)) { 
    return true; 
  }
  
  int currentMins = timeinfo.tm_hour * 60 + timeinfo.tm_min;
  
  for (int i = 0; i < MAX_DOSES; i++) {
    int startMins = prototypeSchedule[i].startHour * 60 + prototypeSchedule[i].startMinute;
    int endMins = prototypeSchedule[i].endHour * 60 + prototypeSchedule[i].endMinute;
    
    if (currentMins >= startMins && currentMins <= endMins) {
      return true;
    }
  }
  return false;
}

void sendTelegramText(String message) {
  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;
    WiFiClientSecure client;
    client.setInsecure(); 
    Serial.println("\n[TELEGRAM] Sending message to caretaker...");
    String url = "https://api.telegram.org/bot" + TELEGRAM_BOT_TOKEN + "/sendMessage";
    http.begin(client, url);
    http.addHeader("Content-Type", "application/json");
    String jsonPayload = "{\"chat_id\":\"" + TELEGRAM_CHAT_ID + "\",\"text\":\"" + message + "\"}";
    http.POST(jsonPayload);
    http.end();
  }
}

// ===== NEW HELPER: URL ENCODE FOR PATIENT MESSAGE =====
String urlencode(String str) {
    String encodedString="";
    char c, code0, code1, code2;
    for (int i =0; i < str.length(); i++){
      c=str.charAt(i);
      if (c == ' '){
        encodedString+= '+';
      } else if (isalnum(c)){
        encodedString+=c;
      } else{
        code1=(c & 0xf)+'0';
        if ((c & 0xf) >9){
            code1=(c & 0xf) - 10 + 'A';
        }
        c=(c>>4)&0xf;
        code0=c+'0';
        if (c > 9){
            code0=c - 10 + 'A';
        }
        code2='\0';
        encodedString+='%';
        encodedString+=code0;
        encodedString+=code1;
      }
      yield();
    }
    return encodedString;
}

